<UserControl x:Class="Bats_Sounds.Controls.EqualizerBars"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="32" Height="24">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="24">
        <Rectangle x:Name="Bar1" Width="5" Height="6"  VerticalAlignment="Bottom" Fill="White" RadiusX="2" RadiusY="2" Margin="0,0,3,0" />
        <Rectangle x:Name="Bar2" Width="5" Height="14" VerticalAlignment="Bottom" Fill="White" RadiusX="2" RadiusY="2" Margin="0,0,3,0" />
        <Rectangle x:Name="Bar3" Width="5" Height="10" VerticalAlignment="Bottom" Fill="White" RadiusX="2" RadiusY="2" Margin="0,0,3,0" />
        <Rectangle x:Name="Bar4" Width="5" Height="8"  VerticalAlignment="Bottom" Fill="White" RadiusX="2" RadiusY="2" />
    </StackPanel>
</UserControl>
